APP_NAME=InfraMedic
ENVIRONMENT=local
CORS_ORIGINS=["http://localhost:5173","http://localhost:4173"]

DATABASE_URL=postgresql+psycopg://inframedic:inframedic@postgres:5432/inframedic
REDIS_URL=redis://redis:6379/0

# Run `floci start` and `floci env | Invoke-Expression`, then copy the matching endpoint and credentials here.
FLOCI_ENDPOINT_URL=http://host.docker.internal:4566
FLOCI_REGION=us-east-1
FLOCI_ACCESS_KEY_ID=floci
FLOCI_SECRET_ACCESS_KEY=floci
FLOCI_BUCKET_NAME=inframedic-artifacts
